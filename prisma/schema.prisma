// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  niche     String
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  locations              Location[]
  categories             Category[]
  items                  Item[]
  itemInstances          ItemInstance[]
  inventoryBalances      InventoryBalance[]
  stockMovements         StockMovement[]
  customers              Customer[]
  bookableResources      BookableResource[]
  bookings               Booking[]
  payments               Payment[]
  availabilityExceptions AvailabilityException[]

  @@map("tenants")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryBalances  InventoryBalance[]
  stockMovementsSrc  StockMovement[]    @relation("SrcLocation")
  stockMovementsDst  StockMovement[]    @relation("DstLocation")

  @@index([tenantId], map: "idx_locations_tenant")
  @@map("locations")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  Item[]

  @@index([tenantId], map: "idx_categories_tenant")
  @@map("categories")
}

model Item {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  sku         String
  name        String
  categoryId  String?  @map("category_id") @db.Uuid
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  itemInstances     ItemInstance[]
  inventoryBalances InventoryBalance[]
  stockMovements    StockMovement[]

  @@unique([tenantId, sku], name: "uq_tenant_sku")
  @@index([tenantId], map: "idx_items_tenant")
  @@map("items")
}

model ItemInstance {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  itemId           String   @map("item_id") @db.Uuid
  trackingNumber   String   @map("tracking_number")
  status           String
  instanceMetadata Json     @default("{}") @map("instance_metadata")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item           Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([tenantId, trackingNumber], name: "uq_tenant_tracking_number")
  @@index([tenantId], map: "idx_instances_tenant")
  @@map("item_instances")
}

model InventoryBalance {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  itemId     String   @map("item_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  quantity   Decimal  @default(0.0000) @db.Decimal(12, 4)
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, itemId, locationId], name: "uq_tenant_item_location")
  @@index([tenantId], map: "idx_inv_balances_tenant")
  @@map("inventory_balances")
}

model StockMovement {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  itemId                String   @map("item_id") @db.Uuid
  itemInstanceId        String?  @map("item_instance_id") @db.Uuid
  type                  String
  quantity              Decimal  @db.Decimal(12, 4)
  sourceLocationId      String?  @map("source_location_id") @db.Uuid
  destinationLocationId String?  @map("destination_location_id") @db.Uuid
  referenceNumber       String?  @map("reference_number")
  notes                 String?
  createdBy             String?  @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item        Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  instance    ItemInstance? @relation(fields: [itemInstanceId], references: [id], onDelete: SetNull)
  sourceLoc   Location?     @relation("SrcLocation", fields: [sourceLocationId], references: [id], onDelete: SetNull)
  destinationLoc Location?   @relation("DstLocation", fields: [destinationLocationId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_movements_tenant")
  @@map("stock_movements")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  email     String
  phone     String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tenantId], map: "idx_customers_tenant")
  @@map("customers")
}

model BookableResource {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  type        String   // 'PHYSICAL' (Villa/Car), 'SLOT' (Consultation Call)
  basePrice   Decimal? @map("base_price") @db.Decimal(12, 2)
  pricingUnit String   @map("pricing_unit") // 'HOURLY', 'DAILY', 'FLAT'
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings               Booking[]
  availabilityExceptions AvailabilityException[]

  @@index([tenantId], map: "idx_resources_tenant")
  @@map("bookable_resources")
}

model Booking {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  customerId          String   @map("customer_id") @db.Uuid
  resourceId          String   @map("resource_id") @db.Uuid
  startTime           DateTime @map("start_time")
  endTime             DateTime @map("end_time")
  status              String   // 'PENDING', 'CONFIRMED', 'COMPLETED', 'CANCELLED'
  totalPrice          Decimal  @map("total_price") @db.Decimal(12, 2)
  paymentStatus       String   @map("payment_status") // 'UNPAID', 'PAID', 'PARTIALLY_REFUNDED', 'NO_REFUND'
  cancellationCharge  Decimal  @default(0.00) @map("cancellation_charge") @db.Decimal(12, 2)
  cancellationReason  String?  @map("cancellation_reason")
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  resource BookableResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([tenantId], map: "idx_bookings_tenant")
  @@map("bookings")
}

model Payment {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  bookingId            String   @map("booking_id") @db.Uuid
  amount               Decimal  @db.Decimal(12, 2)
  paymentMethod        String   @map("payment_method") // 'XENDIT_VA', 'STRIPE', 'TOKEN'
  transactionReference String?  @map("transaction_reference")
  status               String   // 'SUCCESS', 'FAILED', 'PENDING'
  createdAt            DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_payments_tenant")
  @@map("payments")
}

model AvailabilityException {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  resourceId String   @map("resource_id") @db.Uuid
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  reason     String?

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resource BookableResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_exceptions_tenant")
  @@map("availability_exceptions")
}
